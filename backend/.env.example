# =============================================================================
# Satellite Agronomy Intelligence Platform — Backend Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# PostgreSQL (agri_platform database)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/agri_platform

# Firebase / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id

# JWT (Flask-JWT-Extended)
JWT_SECRET_KEY=supersecretkey_change_in_production

# Flask
FLASK_PORT=5000
FLASK_ENV=development

# Google Earth Engine (existing)
GEE_PROJECT_ID=your-gee-project-id
